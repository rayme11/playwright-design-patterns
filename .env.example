# Agentic AI Workflow — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env with real credentials.

# ── Jira ─────────────────────────────────────────────────────────────────────
# Get your API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_api_token_here
JIRA_PROJECT_KEY=LOGIN
# Issue key used by the reporter and self-healer (can be overridden per run)
JIRA_ISSUE_KEY=SCRUM-1

# ── OpenAI (LLM test generation) ─────────────────────────────────────────────
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Model to use for test generation (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ── App under test ───────────────────────────────────────────────────────────
APP_URL=https://the-internet.herokuapp.com
